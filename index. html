<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Mobile Shop</title>
    <style>
        /* General Styles */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f4f7f6; margin: 0; padding: 20px; color: #333; }
        .shop-header { background: #5f259f; color: white; padding: 30px 20px; border-radius: 20px; margin-bottom: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        h1 { margin: 0; font-size: 28px; }
        
        /* Product Card Styles */
        .product-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.08); margin: 0 auto 30px auto; max-width: 400px; overflow: hidden; }
        .product-img { width: 100%; height: auto; border-radius: 15px; margin-bottom: 15px; display: block; }
        .product-name { font-size: 22px; margin: 10px 0; color: #222; }
        .price { font-size: 20px; color: #e91e63; font-weight: bold; margin-bottom: 20px; }

        /* Button Styles */
        .btn { display: flex; align-items: center; justify-content: center; padding: 14px; margin: 10px 0; text-decoration: none; border-radius: 12px; font-weight: bold; color: white; font-size: 16px; transition: transform 0.2s; }
        .btn:active { transform: scale(0.95); }
        .wa-btn { background-color: #25D366; } /* WhatsApp Green */
        .sms-btn { background-color: #007AFF; } /* SMS Blue */
        .btn-icon { margin-right: 10px; font-size: 20px; }
    </style>
</head>
<body>

    <div class="shop-header">
        <h1>Welcome to My Store</h1>
        <p>Order directly via WhatsApp or SMS</p>
    </div>

    <!-- --- PRODUCT 1 START --- -->
    <div class="product-card">
        <!-- 1. Change 'product1.jpg' to your uploaded image name -->
        <img src="product1.jpg" class="product-img" alt="Product One">
        
        <div class="product-name">Your Product Name</div>
        <div class="price">₹999</div>

        <!-- 2. REPLACE 9113688134 with your actual phone number -->
        <a href="https://wa.me" class="btn wa-btn">
            <span class="btn-icon">💬</span> Order on WhatsApp
        </a>

        <!-- 3. REPLACE 9113688134 with your actual phone number -->
        <a href="sms:+910000000000?body=I%20want%20to%20order%20Product%201" class="btn sms-btn">
            <span class="btn-icon">✉️</span> Order via SMS
        </a>
    </div>
    <!-- --- PRODUCT 1 END --- -->

    <p style="color: #888; font-size: 12px;">© 2024 My Mobile Shop. All rights reserved.</p>

</body>
</html>
